---
import '../index.css';
import { getSiteInfo } from '../lib/wp';

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
const siteInfo = await getSiteInfo();

const metaTitle = title ? `${title} | ${siteInfo.name}` : `${siteInfo.name} | ${siteInfo.description}`;
const metaDescription = description || siteInfo.description;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{metaTitle}</title>
		<meta name="description" content={metaDescription} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>
